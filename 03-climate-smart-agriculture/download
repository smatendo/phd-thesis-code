    "# Farm size and reported soil degradation\n",
    "\n",
    "Produces Table 4.13 and the reported Spearman rank correlation.\n",
    "\n",
    "Personal file paths, stored outputs, exploratory analyses, and superseded cells have been removed."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "26fe8196",
   "metadata": {},
   "source": [
    "## Source-selection note\n",
    "\n",
    "The degradation cell in the uploaded notebook extracted only the first numeric token from\n",
    "fraction-style answers and produced values that did not match Table 4.13. This cleaned\n",
    "version preserves the published analysis but replaces that superseded parser with explicit\n",
    "handling of fractions, percentages, decimals, and verbal proportions. The results must be\n",
    "checked against the original questionnaire before public release."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5910c434",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "import warnings\n",
    "\n",
    "PROJECT_DIR = Path.cwd()\n",
    "if PROJECT_DIR.name in {\"notebooks\", \"needs_verification\"}:\n",
    "    PROJECT_DIR = PROJECT_DIR.parent\n",
    "\n",
    "DATA_FILE = PROJECT_DIR / \"data\" / \"questionnaire.xlsx\"\n",
    "OUTPUTS_DIR = PROJECT_DIR / \"outputs\"\n",
    "\n",
    "if not DATA_FILE.exists():\n",
    "    raise FileNotFoundError(\n",
    "        f\"Input file not found: {DATA_FILE}\\n\"\n",
    "        \"Place the anonymised questionnaire file in data/questionnaire.xlsx \"\n",
    "        \"or update DATA_FILE.\"\n",
    "    )\n",
    "\n",
    "OUTPUTS_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from scipy.stats import spearmanr\n",
    "from IPython.display import display\n",
    "\n",
    "OUT_DIR = OUTPUTS_DIR / \"03_soil_degradation\"\n",
    "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "df = pd.read_excel(DATA_FILE)\n",
    "df.columns = df.columns.str.strip()\n",
    "\n",
    "farm_size_col = \"What is the size of your farm (in acres)?\"\n",
    "degradation_col = \"What proportion of your land has been affected by these soil degradation threats?\"\n",
    "\n",
    "for column in [farm_size_col, degradation_col]:\n",
    "    if column not in df.columns:\n",
    "        raise KeyError(f\"Missing questionnaire column: {column}\")\n",
    "\n",
    "df[\"farm_size_acres\"] = (\n",
    "    df[farm_size_col].astype(\"string\")\n",
    "      .str.replace(\",\", \"\", regex=False)\n",
    "      .str.extract(r\"(\\d+(?:\\.\\d+)?)\", expand=False)\n",
    "      .pipe(pd.to_numeric, errors=\"coerce\")\n",
    ")\n",
    "df[\"farm_size_ha\"] = df[\"farm_size_acres\"] * 0.40468564224\n",
    "\n",
    "def parse_proportion_percent(value):\n",
    "    \"\"\"Parse percentage, decimal, fraction, or verbal proportion responses.\"\"\"\n",
    "    if pd.isna(value):\n",
    "        return np.nan\n",
    "\n",
    "    text = str(value).strip().lower()\n",
    "    if not text or text in {\"nan\", \"-\", \"no farm\", \"n/a\", \"na\", \"unknown\", \"i don't know\"}:\n",
    "        return np.nan\n",
    "\n",
    "    verbal = {\n",
    "        \"none\": 0.0,\n",
    "        \"no land\": 0.0,\n",
    "        \"quarter\": 25.0,\n",
    "        \"one quarter\": 25.0,\n",
    "        \"half\": 50.0,\n",
    "        \"one half\": 50.0,\n",
    "        \"three quarters\": 75.0,\n",
    "        \"all\": 100.0,\n",
    "        \"whole\": 100.0,\n",
    "    }\n",
    "    for phrase, value_percent in verbal.items():\n",
    "        if phrase in text:\n",
    "            return value_percent\n",
    "\n",
    "    fraction_match = re.search(r\"(\\d+(?:\\.\\d+)?)\\s*/\\s*(\\d+(?:\\.\\d+)?)\", text)\n",
    "    if fraction_match:\n",
    "        numerator = float(fraction_match.group(1))\n",
    "        denominator = float(fraction_match.group(2))\n",
    "        return 100.0 * numerator / denominator if denominator else np.nan\n",
    "\n",
    "    number_match = re.search(r\"(\\d+(?:\\.\\d+)?)\", text.replace(\",\", \".\"))\n",
    "    if not number_match:\n",
    "        return np.nan\n",
    "\n",
    "    number = float(number_match.group(1))\n",
    "    if \"%\" in text:\n",
    "        return number\n",
    "    if 0 <= number <= 1:\n",
    "        return number * 100\n",
    "    if 1 < number <= 100:\n",
    "        return number\n",
    "    return np.nan\n",
    "\n",
    "df[\"degraded_percent\"] = df[degradation_col].apply(parse_proportion_percent)\n",
    "\n",
    "valid_size = df[\"farm_size_ha\"].dropna()\n",
    "df.loc[valid_size.index, \"farm_size_quartile\"] = pd.qcut(\n",
    "    valid_size,\n",
    "    q=4,\n",
    "    labels=[\"Q1 – smallest\", \"Q2\", \"Q3\", \"Q4 – largest\"],\n",
    ")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7fabd5da",
   "metadata": {},
   "outputs": [],
   "source": [
    "analysis_data = df.dropna(\n",
    "    subset=[\"farm_size_quartile\", \"farm_size_ha\", \"degraded_percent\"]\n",
    ").copy()\n",
    "\n",
    "table_413 = (\n",
    "    analysis_data.groupby(\"farm_size_quartile\", observed=True)[\"degraded_percent\"]\n",
    "      .agg(N=\"count\", Mean_percent_degraded=\"mean\", Median_percent_degraded=\"median\")\n",
    "      .round(1)\n",
    "      .reset_index()\n",
    ")\n",
    "\n",
    "rho, p_value = spearmanr(\n",
    "    analysis_data[\"farm_size_ha\"],\n",
    "    analysis_data[\"degraded_percent\"],\n",
    "    nan_policy=\"omit\",\n",
    ")\n",
    "\n",
    "overall_summary = pd.DataFrame([{\n",
    "    \"N\": len(analysis_data),\n",
    "    \"Mean_percent_degraded\": analysis_data[\"degraded_percent\"].mean(),\n",
    "    \"SD_percent_degraded\": analysis_data[\"degraded_percent\"].std(ddof=1),\n",
    "    \"Median_percent_degraded\": analysis_data[\"degraded_percent\"].median(),\n",
    "    \"Minimum\": analysis_data[\"degraded_percent\"].min(),\n",
    "    \"Maximum\": analysis_data[\"degraded_percent\"].max(),\n",
    "    \"Spearman_rho\": rho,\n",
    "    \"Spearman_p_value\": p_value,\n",
    "}]).round(3)\n",
    "\n",
    "table_413.to_excel(OUT_DIR / \"table_4_13_degradation_by_farm_size.xlsx\", index=False)\n",
    "overall_summary.to_excel(OUT_DIR / \"soil_degradation_overall_and_spearman.xlsx\", index=False)\n",
    "\n",
    "display(table_413)\n",
    "display(overall_summary)\n",
    "\n",
    "# Published-value check: this does not replace the calculations.\n",
    "expected = pd.DataFrame({\n",
    "    \"farm_size_quartile\": [\"Q1 – smallest\", \"Q2\", \"Q3\", \"Q4 – largest\"],\n",
    "    \"N\": [69, 62, 34, 51],\n",
    "    \"Mean_percent_degraded\": [52.8, 36.4, 30.6, 24.1],\n",
    "    \"Median_percent_degraded\": [50.0, 25.0, 16.7, 15.0],\n",
    "})\n",
    "print(\"\\nPublished Table 4.13 reference:\")\n",
    "display(expected)\n",
    "print(f\"Published Spearman result: rho = -0.43, p < 0.001\")\n"
   ]
  }
