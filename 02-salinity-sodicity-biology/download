    "# Sensitivity ANCOVA models using MIR-predicted EC1:2\n",
    "\n",
    "Reproduces Tables A.1 and A.2. This is the published sensitivity analysis; it is kept separate from the main laboratory-EC ANCOVA.\n",
    "\n",
    "The notebook contains only the analysis retained in the final thesis. Exploratory alternatives, superseded cells, personal paths, saved outputs, and unpublished figure-formatting trials have been removed."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e5fd7c00",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "\n",
    "PROJECT_DIR = Path.cwd()\n",
    "if PROJECT_DIR.name == \"notebooks\":\n",
    "    PROJECT_DIR = PROJECT_DIR.parent\n",
    "\n",
    "DATA_DIR = PROJECT_DIR / \"data\"\n",
    "OUTPUTS_DIR = PROJECT_DIR / \"outputs\"\n",
    "\n",
    "SOIL_FILE = DATA_DIR / \"soil_data.xlsx\"\n",
    "SOIL_SHEET = \"PredictionNewSamplesSalinity_Fi\"\n",
    "\n",
    "if not SOIL_FILE.exists():\n",
    "    raise FileNotFoundError(\n",
    "        f\"Input file not found: {SOIL_FILE}\\n\"\n",
    "        \"Place the soil dataset in the data folder and name it 'soil_data.xlsx', \"\n",
    "        \"or update SOIL_FILE in this notebook.\"\n",
    "    )\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import statsmodels.api as sm\n",
    "import statsmodels.formula.api as smf\n",
    "\n",
    "from IPython.display import display\n",
    "from statsmodels.stats.anova import anova_lm\n",
    "from statsmodels.stats.outliers_influence import variance_inflation_factor\n",
    "\n",
    "OUT_DIR = OUTPUTS_DIR / \"07_ancova_sensitivity_ec12\"\n",
    "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "df = pd.read_excel(SOIL_FILE, sheet_name=SOIL_SHEET)\n",
    "df.columns = df.columns.str.strip()\n",
    "\n",
    "required_columns = [\n",
    "    \"SITE\", \"Layer\", \"EC 1:2 (dS/cm)\", \"ESP est\",\n",
    "    \"TotalBacteria\", \"TotalFungi\", \"TYPES_BACTERIA\", \"TYPES_FUNGI\",\n",
    "    \"SOC (%)\", \"Clay (%)\", \"pH\"\n",
    "]\n",
    "missing = [column for column in required_columns if column not in df.columns]\n",
    "if missing:\n",
    "    raise ValueError(f\"Missing required columns: {missing}\")\n",
    "\n",
    "df[\"Zone\"] = df[\"SITE\"].astype(str).str.strip().str.upper()\n",
    "df = df[df[\"Zone\"].isin([\"PERKERRA\", \"TANA\"])].copy()\n",
    "\n",
    "for column in required_columns[1:]:\n",
    "    df[column] = pd.to_numeric(df[column], errors=\"coerce\")\n",
    "\n",
    "df = df.rename(columns={\n",
    "    \"EC 1:2 (dS/cm)\": \"EC12_spectral\",\n",
    "    \"ESP est\": \"ESP\",\n",
    "    \"TYPES_BACTERIA\": \"BacterialRichness\",\n",
    "    \"TYPES_FUNGI\": \"FungalRichness\",\n",
    "    \"SOC (%)\": \"SOC\",\n",
    "    \"Clay (%)\": \"Clay\"\n",
    "})\n",
    "\n",
    "df[\"Layer_cat\"] = pd.Categorical(\n",
    "    df[\"Layer\"].astype(\"Int64\").astype(str),\n",
    "    categories=[\"1\", \"2\", \"3\"],\n",
    "    ordered=True\n",
    ")\n",
    "df[\"Zone\"] = pd.Categorical(\n",
    "    df[\"Zone\"], categories=[\"PERKERRA\", \"TANA\"], ordered=True\n",
    ")\n",
    "\n",
    "df[\"log_TotalBacteria\"] = np.log1p(df[\"TotalBacteria\"])\n",
    "df[\"log_TotalFungi\"] = np.log1p(df[\"TotalFungi\"])\n",
    "\n",
    "print(\"Dataset shape:\", df.shape)\n",
    "print(pd.crosstab(df[\"Zone\"], df[\"Layer_cat\"]))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "181451ca",
   "metadata": {},
   "outputs": [],
   "source": [
    "responses = {\n",
    "    \"log_TotalBacteria\": \"Total bacteria, log-transformed\",\n",
    "    \"log_TotalFungi\": \"Total fungi, log-transformed\",\n",
    "    \"BacterialRichness\": \"Bacterial richness\",\n",
    "    \"FungalRichness\": \"Fungal richness\",\n",
    "}\n",
    "\n",
    "formula_template = \"\"\"\n",
    "{response} ~ C(Layer_cat) * C(Zone)\n",
    "+ EC12_spectral * C(Zone)\n",
    "+ ESP * C(Zone)\n",
    "+ SOC + Clay + pH\n",
    "\"\"\"\n",
    "\n",
    "term_labels = {\n",
    "    \"C(Layer_cat)\": \"Depth\",\n",
    "    \"C(Zone)\": \"Irrigation scheme\",\n",
    "    \"C(Layer_cat):C(Zone)\": \"Depth × irrigation scheme\",\n",
    "    \"EC12_spectral\": r\"MIR-predicted EC$_{1:2}$\",\n",
    "    \"EC12_spectral:C(Zone)\": r\"MIR-predicted EC$_{1:2}$ × irrigation scheme\",\n",
    "    \"ESP\": \"ESP\",\n",
    "    \"ESP:C(Zone)\": \"ESP × irrigation scheme\",\n",
    "    \"SOC\": \"SOC\",\n",
    "    \"Clay\": \"Clay\",\n",
    "    \"pH\": \"pH\",\n",
    "    \"Residual\": \"Residual\",\n",
    "}\n",
    "\n",
    "all_tables = []\n",
    "all_metrics = []\n",
    "\n",
    "for response, response_label in responses.items():\n",
    "    columns = [\n",
    "        response, \"Layer_cat\", \"Zone\", \"EC12_spectral\",\n",
    "        \"ESP\", \"SOC\", \"Clay\", \"pH\"\n",
    "    ]\n",
    "    model_data = df[columns].dropna().copy()\n",
    "    formula = formula_template.format(response=response)\n",
    "\n",
    "    model = smf.ols(formula=formula, data=model_data).fit()\n",
    "    table = anova_lm(model, typ=2, robust=\"hc3\").reset_index()\n",
    "    table = table.rename(columns={\n",
    "        \"index\": \"term\",\n",
    "        \"df\": \"df\",\n",
    "        \"F\": \"F_value\",\n",
    "        \"PR(>F)\": \"p_value\"\n",
    "    })\n",
    "    table[\"Response\"] = response_label\n",
    "    table[\"Term_label\"] = table[\"term\"].map(term_labels).fillna(table[\"term\"])\n",
    "    table[\"N\"] = int(model.nobs)\n",
    "    all_tables.append(table)\n",
    "\n",
    "    all_metrics.append({\n",
    "        \"Response\": response_label,\n",
    "        \"N\": int(model.nobs),\n",
    "        \"R2\": model.rsquared,\n",
    "        \"Adjusted_R2\": model.rsquared_adj,\n",
    "        \"AIC\": model.aic,\n",
    "        \"BIC\": model.bic,\n",
    "    })\n",
    "\n",
    "ancova_hc3 = pd.concat(all_tables, ignore_index=True)\n",
    "metrics = pd.DataFrame(all_metrics)\n",
    "\n",
    "ancova_hc3.to_excel(OUT_DIR / \"SENSITIVITY_EC12_typeII_HC3_full.xlsx\", index=False)\n",
    "metrics.to_excel(OUT_DIR / \"SENSITIVITY_EC12_model_metrics.xlsx\", index=False)\n",
    "\n",
    "display(ancova_hc3)\n",
    "display(metrics)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "090a8cd0",
   "metadata": {},
   "outputs": [],
   "source": [
    "# VIF for the continuous predictors used in the ANCOVA models\n",
    "continuous_predictors = [\"EC12_spectral\", \"ESP\", \"SOC\", \"Clay\", \"pH\"]\n",
    "vif_data = df[continuous_predictors].dropna().copy()\n",
    "vif_data = (vif_data - vif_data.mean()) / vif_data.std(ddof=0)\n",
    "X = sm.add_constant(vif_data)\n",
    "\n",
    "vif_table = pd.DataFrame({\n",
    "    \"Variable\": X.columns,\n",
    "    \"VIF\": [\n",
    "        variance_inflation_factor(X.values, index)\n",
    "        for index in range(X.shape[1])\n",
    "    ]\n",
    "})\n",
    "vif_table.to_excel(OUT_DIR / \"SENSITIVITY_EC12_VIF.xlsx\", index=False)\n",
    "display(vif_table)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "57f49fca",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tables A.1 and A.2 report all non-residual terms from the sensitivity models.\n",
    "publication_table = ancova_hc3[ancova_hc3[\"term\"] != \"Residual\"].copy()\n",
    "\n",
    "abundance_responses = [\n",
    "    \"Total bacteria, log-transformed\",\n",
    "    \"Total fungi, log-transformed\",\n",
    "]\n",
    "richness_responses = [\n",
    "    \"Bacterial richness\",\n",
    "    \"Fungal richness\",\n",
    "]\n",
    "\n",
    "table_a1 = publication_table[\n",
    "    publication_table[\"Response\"].isin(abundance_responses)\n",
    "][[\"Response\", \"Term_label\", \"df\", \"F_value\", \"p_value\"]].copy()\n",
    "\n",
    "table_a2 = publication_table[\n",
    "    publication_table[\"Response\"].isin(richness_responses)\n",
    "][[\"Response\", \"Term_label\", \"df\", \"F_value\", \"p_value\"]].copy()\n",
    "\n",
    "table_a1.to_excel(OUT_DIR / \"table_A_1_ancova_sensitivity_abundance.xlsx\", index=False)\n",
    "table_a2.to_excel(OUT_DIR / \"table_A_2_ancova_sensitivity_richness.xlsx\", index=False)\n",
    "\n",
    "display(table_a1)\n",
    "display(table_a2)\n"
   ]
  }
